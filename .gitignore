# Existing content from src/.gitignore
*.blade.php diff=html
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

/.github export-ignore
CHANGELOG.md export-ignore

# Additional content
/node_modules
/public/hot
/public/storage
/storage/*.key
/vendor
.env
.env.backup
.phpunit.result.cache
docker-compose.override.yml
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log
/.idea
/.vscode

# Docker MySQL data directory
docker/mysql/data/

# 一時ファイル（API キー投入用・コミット禁止）
scripts/_local_openai.txt

# Terraform
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfvars
*.tfstate
*.tfstate.*
.bin/src/node_modules/
